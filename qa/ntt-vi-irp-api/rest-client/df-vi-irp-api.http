@DOCUMENT_ID = 615
@NOTICE_NO = 22900827

### Document GET /documents/<document>/<correlation>
GET https://{{host}}{{api_path}}/documents/{{DOCUMENT_ID}}/steve-test-{{$guid}}
Authorization: Basic {{api_username}} {{api_password}}
Accept: application/json

### Document POST
# Example command-line:
# https --verbose --auth "${USERNAME}:${PASSWORD}" POST digitalforms-viirp-api-c220ad-dev.apps.silver.devops.gov.bc.ca/digitalforms-viirp/v1/documents/steve-test-2 < document-post-payload.json
POST https://{{host}}{{api_path}}/documents/steve-test-{{$guid}}
Authorization: Basic {{api_username}} {{api_password}}
Content-Type: application/json

{
  "type_code": "MV2702A",
  "mime_type": "application",
  "mime_sub_type": "pdf",
  "file_object": 
    // Tiny base64-encoded PDF: https://stackoverflow.com/questions/17279712/what-is-the-smallest-possible-valid-pdf
    "",
  "notice_type_code": "IRP",
  "notice_subject_code": "VEHI",
  "pageCount": 1
}

### Document GET /documents/list/<noticeNo>>/<correlation>
GET https://{{host}}{{api_path}}/documents/list/{{NOTICE_NO}}/steve-test-{{$guid}}
Authorization: Basic {{api_username}} {{api_password}}
Accept: application/json

### Document POST association with prohibition
# Example command-line:
# https --verbose --auth "${USERNAME}:${PASSWORD}" POST digitalforms-viirp-api-c220ad-dev.apps.silver.devops.gov.bc.ca/digitalforms-viirp/v1/documents/association/notice/611/steve-test-2 noticeNo=20100155 noticeTypeCd=IRP
POST https://{{host}}{{api_path}}/documents/association/notice/{{DOCUMENT_ID}}/steve-test-{{$guid}}
Authorization: Basic {{api_username}} {{api_password}}
Content-Type: application/json

{
  "noticeNo":   {{NOTICE_NO}},
  "noticeTypeCd": "IMP"
}



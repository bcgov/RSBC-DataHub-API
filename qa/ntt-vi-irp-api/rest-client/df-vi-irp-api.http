#        file, under "rest-client.environmentVariables". See HTTP CLient documentation. Example:
#         "DF-VI-IRP-API-DEV":{
#             "name": "DEV c220ad-dev svc/digitalforms-viirp-api-svc",
#             "host": "digitalforms-viirp-api-c220ad-dev.apps.silver.devops.gov.bc.ca",
#             "api_path": "/digitalforms-viirp/v1",
#             "api_username": "_________",
#             "api_password": "_________"
#         },

DELETE https://{{ORDS_DELETE_REVIEW_TIME_URL}}/{{NOTICE_NUMBER}}/review/schedule/{{FORM_TYPE}}/{{application_id}}




### CREATE NEW PROHIBITION REVIEW APPLICATION
#############################################
# Disconnect from VPN to run this command, or run on OpenShift pod.
# Example: POST http://wsgw.dev.jag.gov.bc.ca/digitalforms/ADP/21900104/application/saf1044
@correlation_id = {{CORRELATION}}-3003
POST http://{{DFAPI_URL}}/{{FORM_TYPE}}/{{NOTICE_NUMBER}}/application/{{correlation_id}}
Authorization: Basic {{DFAPI_CREDENTIALS}}
Content-Type: application/json

{
  "applicationInfo": {
    "email": "steve.1.forsyth@gov.bc.ca",
    "faxNo": "2501112222",
    "firstGivenNm": "Steve",
    "formData": "",
    "manualEntryYN": "N",
    "noticeSubjectCd": "PERS",
    "phoneNo": "2501113333",
    "presentationTypeCd": "{{PRESENTATION_TYPE}}",
    "reviewRoleTypeCd": "{{REVIEW_ROLE_TYPE}}",
    "secondGivenNm": "Two",
    "surnameNm": "Lungpayne"
  }
}

